<%- include('../partials/topbar') %>

<%- include('../partials/ticker') %>

<%- include('../partials/slider') %>

<%- include('../partials/auth-buttons') %>

<section class="parlay-page with-home-bg">

  <!-- HERO -->
  <section class="parlay-hero">

    <div class="container">

      <div class="hero-box">

        <span class="hero-badge">
          🔥 PREDIKSI PARLAY TERUPDATE
        </span>

        <h1>
          PREDIKSI PARLAY JITU
        </h1>

        <p>
          Update prediksi parlay malam ini
          berdasarkan pertandingan aktif,
          statistik tim, performa terbaru,
          dan analisa otomatis AI.
        </p>

        <div class="hero-stats">

          <div class="hero-stat">
            <strong>
              <%= posts.length %>+
            </strong>
            <span>
              Prediksi Hari Ini
            </span>
          </div>

          <div class="hero-stat">
            <strong>
              LIVE
            </strong>
            <span>
              Update Otomatis
            </span>
          </div>

          <div class="hero-stat">
            <strong>
              AI
            </strong>
            <span>
              Analisa Match
            </span>
          </div>

        </div>

      </div>

    </div>

  </section>

  <!-- CONTENT -->
  <main class="container parlay-layout">

    <!-- LEFT -->
    <section class="parlay-list">

      <% if (!posts.length) { %>

        <article class="parlay-empty">

          <div class="empty-icon">
            ⚽
          </div>

          <h3>
            Belum Ada Prediksi
          </h3>

          <p>
            Prediksi parlay otomatis
            akan segera diperbarui.
          </p>

        </article>

      <% } %>

      <% posts.forEach(function(post){ %>

        <article class="parlay-card">

          <!-- IMAGE -->
          <a
            class="parlay-thumb"
            href="<%= parlayUrl(post) %>"
          >

            <img
              src="<%= post.thumbnail %>"
              alt="<%= post.title %>"
              loading="lazy"
            >

            <div class="thumb-overlay">

              <span>
                🔥 HOT MATCH
              </span>

            </div>

          </a>

          <!-- BODY -->
          <div class="parlay-body">

            <!-- TOP -->
            <div class="post-top">

              <a
                class="badge"

                href="/category/<%= String(post.category || '')
                .toLowerCase()
                .replace(/[^a-z0-9]+/g,'-')
                .replace(/^-|-$/g,'') %>"
              >

                <%= post.category || 'Prediksi Parlay' %>

              </a>

              <span class="date-mini">

                🕒 <%= fmtDate(post.createdAt) %>

              </span>

            </div>

            <!-- TITLE -->
            <h2>

              <a href="<%= parlayUrl(post) %>">

                <%= post.title %>

              </a>

            </h2>

            <!-- META -->
            <div class="post-meta">

              <span>
                👑
                <%= post.author || 'Master Parlay' %>
              </span>

              <span>
                ⚽ Analisa AI
              </span>

              <span>
                🔥 Auto Update
              </span>

            </div>

            <!-- DESC -->
            <p>

              <%= post.excerpt %>

            </p>

            <!-- BUTTON -->
            <div class="post-actions">

              <a
                href="<%= parlayUrl(post) %>"
                class="read-btn"
              >

                LIHAT PREDIKSI →

              </a>

            </div>

          </div>

        </article>

      <% }) %>

      <!-- PAGINATION -->
      <div class="pagination">

        <% if (currentPage > 1) { %>

          <a
            href="/prediksi-parlay?page=<%= currentPage - 1 %>"
          >

            ‹

          </a>

        <% } %>

        <% for(let i=1; i<=totalPages; i++){ %>

          <% if (
            i === currentPage ||
            i <= 2 ||
            i === totalPages ||
            Math.abs(i-currentPage)<=1
          ) { %>

            <a
              class="<%= i === currentPage ? 'on' : '' %>"

              href="/prediksi-parlay?page=<%= i %>"
            >

              <%= i %>

            </a>

          <% } else if (
            i === 3 &&
            currentPage > 4
          ) { %>

            <span>...</span>

          <% } %>

        <% } %>

        <% if (currentPage < totalPages) { %>

          <a
            href="/prediksi-parlay?page=<%= currentPage + 1 %>"
          >

            ›

          </a>

        <% } %>

      </div>

    </section>

    <!-- SIDEBAR -->
    <%- include(
      '../partials/sidebar-blog',
      {
        latestPosts: allPosts.slice(0, 8),
        ads
      }
    ) %>

  </main>

</section>

<%- include('../partials/footer') %>

<%- include('../partials/quick-menu') %>
